# Web (Next.js 15 + React 19 RC)
node_modules/
.next/
out/
build/
dist/
.env*.local
.turbo/
next-env.d.ts
*.tsbuildinfo
.swc/

# Media cache (working dir, never commit)
.mavis-cache/
public/.next-tmp/

# All media lives on the CDN at resources.positiveness.club/heal.
# Never commit audio/illustration assets — they're served from the CDN.
*.mp3
*.wav
*.m4a
*.ogg
*.flac
*.png
*.jpg
*.jpeg
*.webp
*.avif
*.gif
*.bmp
*.tiff
*.ico

# But do allow the small icon assets in public/
!public/icon.svg
!public/favicon.ico
!public/manifest.json

# Flutter output if cross-mounted
*.dart_tool/

# Generated content (data lives in PB)
content/**/*.mp3
content/**/*.png
content/**/*.jpg
content/**/*.webp