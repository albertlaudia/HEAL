<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>HEAL</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.pclub.heal</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>heal</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- ─── Permission usage strings ─────────────────────────────────────── -->

	<!-- Microphone: used by Breath Studio to learn your natural inhale/exhale
	     duration. We never store or upload audio — only the breath timing. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>HEAL listens to the rhythm of your breath to learn your natural pace. We never record or upload audio — only the timing stays on your device.</string>

	<!-- Notifications: gentle daily reminders for morning and evening practice.
	     You can disable these any time in Settings. -->
	<key>NSUserNotificationsUsageDescription</key>
	<string>HEAL sends gentle daily reminders for your morning and evening practice. You can disable these any time in Settings.</string>

	<!-- ─── App Tracking Transparency (iOS 14+) ──────────────────────────── -->
	<!-- HEAL does NOT track users across apps or websites. We declare this
	     string so iOS can present the system tracking prompt when the app
	     first launches. Because we never actually call ATT.request(),
	     iOS won't show the prompt — but having the key in place is the
	     App Store policy requirement. If a future feature ever wants to
	     track, the string below is the one users would see. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>This identifier will be used to deliver personalized practice reminders and remember your progress across devices.</string>

	<!-- ─── iOS 17+ Declared Age Range ───────────────────────────────────── -->
	<!-- HEAL is rated 4+ (kids category). No age range is needed since we
	     don't gate any features. -->

	<!-- ─── Required reason API declarations ─────────────────────────────── -->
	<!-- iOS 17 requires apps to declare reasons for using "Required Reason
	     API" categories. See PrivacyInfo.xcprivacy for the full set. -->

	<!-- ─── Network usage ────────────────────────────────────────────────── -->
	<!-- HEAL only connects to known endpoints (pocketbase.scaleupcrm.com,
	     resources.positiveness.club, *.googleapis.com, *.firebaseio.com).
	     We use ATS (App Transport Security) defaults — HTTPS only. -->

	<!-- Audio background mode: continues playback when device is locked -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>

	<!-- Google Sign In: REVERSED_CLIENT_ID from GoogleService-Info.plist -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.googleusercontent.apps.355529098583-af67c13qac54rsvk1hhiseals6g6n7f5</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.355529098583-af67c13qac54rsvk1hhiseals6g6n7f5</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.pclub.heal.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>healf</string>
			</array>
		</dict>
	</array>

	<!-- Apple Sign In -->
	<key>ASAuthenticationServicesApplication</key>
	<array>
		<string>com.apple.developer.applesignin</string>
	</array>
</dict>
</plist>
