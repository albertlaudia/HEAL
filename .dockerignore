# Root .dockerignore — applied when building the entire monorepo
# (When building /web specifically, the build context is just that folder.)
node_modules
.next
out
build
dist
.git
.gitignore
.github
mobile
content
docs
scripts/.cache
b2-cache
*.log
*.tsbuildinfo
.env
.env.local
.env.*.local
.DS_Store
.eslintrc.json
coverage
playwright-report
test-results
.mavis-cache/

# Exclude heavy subfolders from the /web build context too
# (this file is also used when build context is /web via Dokploy)
**/node_modules/
**/.next/
**/build/
**/.dart_tool/
**/public/images/**
**/public/audio/meditations/**
**/public/audio/praise/**
